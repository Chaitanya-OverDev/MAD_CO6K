<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ProgressBar android:id="@+id/p1" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100"/>
    <ProgressBar android:id="@+id/p2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
    <TextView android:id="@+id/tv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status" />
    <Button android:id="@+id/b1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Task (AsyncTask)" />
    <Button android:id="@+id/b2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Progress" />

</LinearLayout>